# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/societywale_db

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Super Admin (seeded on first run)
SUPER_ADMIN_EMAIL=superadmin@societywale.com
# Optional: if set, only the super admin uses this password; other seed users use SEED_USER_PASSWORD
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# One password for all other seeded demo users (society admin + residents). Default is 12 characters.
SEED_USER_PASSWORD=SamplePass12

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — Nodemailer (SMTP). Used for password reset, welcomes, complaints, subscription alerts.
# Optional legacy aliases if unset: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, MAIL_FROM_NAME
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@societywale.com
EMAIL_FROM_NAME=SocietyWale

# Login link in “new society admin” emails (defaults to APP_URL or https://app.societywale.in)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
