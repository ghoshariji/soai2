{
  "info": {
    "name": "SocietyWale Platform API",
    "description": "Multi-tenant Society Management SaaS API",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"superadmin@societywale.com\",\"password\":\"SuperAdmin@123\"}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh-token",
            "body": { "mode": "raw", "raw": "{\"refreshToken\":\"{{refresh_token}}\"}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/logout"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/change-password",
            "body": { "mode": "raw", "raw": "{\"currentPassword\":\"SuperAdmin@123\",\"newPassword\":\"NewPass@456\"}" }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Super Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/dashboard/super-admin"
          }
        },
        {
          "name": "Society Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/dashboard/society-admin"
          }
        }
      ]
    },
    {
      "name": "Societies",
      "item": [
        {
          "name": "Create Society",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/societies",
            "body": { "mode": "raw", "raw": "{\"name\":\"Sunrise Apartments\",\"address\":\"45 Park Avenue\",\"city\":\"Delhi\",\"plan\":\"premium\",\"expiryDate\":\"2026-12-31\",\"adminName\":\"John Doe\",\"adminEmail\":\"admin@sunrise.com\"}" }
          }
        },
        {
          "name": "Get All Societies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/societies?page=1&limit=10&search=", "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"},{"key":"search","value":""}] }
          }
        },
        {
          "name": "Get Society by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/societies/:id"
          }
        },
        {
          "name": "Update Society",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/societies/:id",
            "body": { "mode": "raw", "raw": "{\"name\":\"Updated Name\",\"city\":\"Mumbai\"}" }
          }
        },
        {
          "name": "Toggle Society Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/societies/:id/toggle-status"
          }
        },
        {
          "name": "Delete Society",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/societies/:id"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users",
            "body": { "mode": "raw", "raw": "{\"name\":\"Jane Smith\",\"email\":\"jane@society.com\",\"phone\":\"9876543210\",\"flatNumber\":\"D-404\"}" }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/users?page=1&limit=20&search=&status=", "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"},{"key":"search","value":""},{"key":"status","value":""}] }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/users/me",
            "body": { "mode": "formdata", "formdata": [{"key":"name","value":"Updated Name"},{"key":"phone","value":"9876543299"},{"key":"profilePhoto","type":"file"}] }
          }
        },
        {
          "name": "Toggle User Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/users/:id/toggle-status",
            "body": { "mode": "raw", "raw": "{\"status\":\"blocked\"}" }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get My Subscription",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/subscriptions/my"
          }
        },
        {
          "name": "Get All Subscriptions (Super Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/subscriptions"
          }
        },
        {
          "name": "Update Subscription",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/subscriptions/:societyId",
            "body": { "mode": "raw", "raw": "{\"plan\":\"premium\",\"expiryDate\":\"2027-01-01\",\"price\":5000}" }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/posts",
            "body": { "mode": "formdata", "formdata": [{"key":"content","value":"Hello from the community!"},{"key":"images","type":"file"}] }
          }
        },
        {
          "name": "Get Posts (Feed)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/posts?page=1&limit=10", "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}] }
          }
        },
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/posts/:id/like"
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/posts/:id/comments",
            "body": { "mode": "raw", "raw": "{\"content\":\"Great post!\"}" }
          }
        }
      ]
    },
    {
      "name": "Announcements",
      "item": [
        {
          "name": "Create Announcement",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/announcements",
            "body": { "mode": "formdata", "formdata": [{"key":"title","value":"Water Shutdown"},{"key":"description","value":"Water will be shut off on Sunday from 10am-2pm"},{"key":"priority","value":"important"},{"key":"image","type":"file"}] }
          }
        },
        {
          "name": "Get Announcements",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/announcements?page=1&limit=10"
          }
        },
        {
          "name": "Mark Announcement as Read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/announcements/:id/read"
          }
        }
      ]
    },
    {
      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/complaints",
            "body": { "mode": "formdata", "formdata": [{"key":"title","value":"Broken Lift"},{"key":"description","value":"The lift on Block B is not working since 2 days"},{"key":"category","value":"maintenance"},{"key":"priority","value":"high"}] }
          }
        },
        {
          "name": "Get Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/complaints?status=open"
          }
        },
        {
          "name": "Update Complaint Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/complaints/:id/status",
            "body": { "mode": "raw", "raw": "{\"status\":\"in_progress\",\"adminComment\":\"We are looking into this issue.\"}" }
          }
        }
      ]
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/groups",
            "body": { "mode": "raw", "raw": "{\"name\":\"Tower A Residents\",\"description\":\"Group for Tower A residents\"}" }
          }
        },
        {
          "name": "Get Groups",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/groups"
          }
        },
        {
          "name": "Add Member to Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/groups/:id/members",
            "body": { "mode": "raw", "raw": "{\"userIds\":[\"userId1\",\"userId2\"]}" }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get Conversations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/chat/conversations"
          }
        },
        {
          "name": "Get Personal Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/chat/personal/:userId?page=1&limit=20"
          }
        },
        {
          "name": "Get Group Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/chat/group/:groupId?page=1&limit=20"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/notifications?page=1&limit=20"
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/notifications/unread-count"
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/notifications/read-all"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Bulk Upload Users (Excel)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/upload/excel",
            "body": { "mode": "formdata", "formdata": [{"key":"file","type":"file","description":"Excel file (.xlsx) with columns: Name, Email, Phone, FlatNumber"}] }
          }
        }
      ]
    }
  ]
}
